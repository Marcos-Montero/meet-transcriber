{
  "name": "comeet",
  "version": "1.0.2",
  "description": "Meeting transcription app with speaker recognition and AI analysis",
  "author": "Marcos Montero",
  "private": true,
  "main": "out/main/main.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --mac --arm64 --x64",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@deepgram/sdk": "^5.0.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.marcosmontero.comeet",
    "productName": "Comeet",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": ".env.local",
        "to": ".env.local"
      }
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Marcos-Montero",
      "repo": "meet-transcriber",
      "releaseType": "release"
    }
  }
}
